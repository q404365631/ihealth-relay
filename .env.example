# =============================================================================
# ihealth-relay 環境変数サンプル
# 使い方: cp .env.example .env してから各値を書き換える
# =============================================================================

# --- Notion API ---
# https://www.notion.so/my-integrations で作成したインテグレーションのシークレット
# (旧 GoogleFitNotionIntegration からそのまま引き継ぎ可能)
NOTION_SECRET=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 日記 DB の ID (URL の末尾 32文字)
DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Health Auto Export ---
# Health Auto Export Premium の AutoSync 機能が .hae (LZFSE 圧縮 JSON) を書き出す
# iCloud Drive 上の固定フォルダ。この直下に HealthMetrics/{metric}/{YYYYMMDD}.hae が並ぶ。
# 先頭の `~/` はホームディレクトリに展開される。
# 中間の `~` (iCloud~com~ifunography~HealthExport) はフォルダ名の一部なので展開されない。
HEALTH_EXPORT_DIR=~/Library/Mobile Documents/iCloud~com~ifunography~HealthExport/Documents/AutoSync

# --- 個人プロファイル (運動強度スコア = Heart Points 算出に使用) ---
# 最大心拍数 = 205.8 - 0.685 × age (Tanaka 式)。誕生日から動的に age を算出。
# 下の値はダミーです。自分の誕生日に必ず書き換えてください。
BIRTH_DATE=1990-01-01

# --- ログ ---
# debug / info / warning / error
LOG_LEVEL=info
